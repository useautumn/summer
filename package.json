{
  "name": "@useautumn/summer",
  "version": "0.1.2",
  "description": "Local AI coding usage meter for Autumn.",
  "type": "module",
  "bin": {
    "summer": "./src/cli.ts"
  },
  "files": [
    "src",
    "dash/dist",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "d": "SUMMER_AUTUMN_API_URL=https://api.useautumn.com SUMMER_AUTUMN_APP_URL=https://app.useautumn.com bun src/cli.ts",
    "dl": "SUMMER_DIR=.summer-dev SUMMER_OTLP_PORT=4329 SUMMER_AUTUMN_API_URL=http://localhost:8080 SUMMER_AUTUMN_APP_URL=http://localhost:3000 bun src/cli.ts",
    "dev": "SUMMER_DIR=.summer-dev SUMMER_OTLP_PORT=4329 SUMMER_AUTUMN_API_URL=http://localhost:8080 SUMMER_AUTUMN_APP_URL=http://localhost:3000 bun src/cli.ts",
    "ts": "tsc --noEmit",
    "test": "bun test",
    "build:dash": "cd dash && bun install && bun run build",
    "release": "bun run ts && bun run build:dash && bun publish --access public"
  },
  "dependencies": {
    "arctic": "^3.7.0",
    "autumn-js": "^1.2.29",
    "commander": "^15.0.0",
    "evlog": "^2.19.1",
    "hono": "^4.12.0",
    "open": "^11.0.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0"
  }
}
